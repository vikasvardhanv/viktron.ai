# Viktron.ai — Frontend Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── API Backend ────────────────────────────────────────────────────────────────
# URL of the FastAPI backend (no trailing slash)
VITE_API_URL=https://viktron-ai.vercel.app

# ── Auth ───────────────────────────────────────────────────────────────────────
# Google OAuth client ID (for Google Sign-In button)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── AI / LLM ──────────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=your-gemini-api-key

# ── Error Tracking ────────────────────────────────────────────────────────────
# Sentry DSN — get from sentry.io project settings
VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXXX
VITE_SENTRY_ENVIRONMENT=development

# ── Feature Flags / Misc ──────────────────────────────────────────────────────
# Proxy target for local API development (optional — only set if running backend locally)
# VITE_API_PROXY=http://localhost:8000

# ── Server (Node.js Express) ──────────────────────────────────────────────────
# FastAPI backend URL — Node.js proxies analytics/agentirl/onboarding routes here
FASTAPI_BASE_URL=https://api.viktron.ai
